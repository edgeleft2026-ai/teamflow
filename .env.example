# TeamFlow Environment Variables
# Copy this file to .env and fill in your credentials.
# .env is gitignored and should NEVER be committed.
#
# Priority: .env file → environment variables → config.yaml
# Sensitive values (secrets, tokens) MUST go in .env, NOT in config.yaml.

# === Feishu / Lark Application ===
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BRAND=feishu
FEISHU_ADMIN_OPEN_ID=

# === Agent / AI Configuration ===
# Provider identifier (e.g. openai, deepseek, anthropic, minimax-cn)
AGENT_PROVIDER=
AGENT_API_MODE=
AGENT_MCP_TOOLS=im.v1.*,docx.v1.*
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=120

# Model routing (can be overridden per deployment)
# TEAMFLOW_FAST_MODEL=openai/gpt-4o-mini
# TEAMFLOW_SMART_MODEL=openai/gpt-4o
# TEAMFLOW_REASONING_MODEL=openai/gpt-4o

# === Gitea (Self-hosted Git) ===
GITEA_BASE_URL=https://git.example.com
GITEA_ACCESS_TOKEN=
GITEA_DEFAULT_PRIVATE=true
GITEA_AUTO_CREATE=true
GITEA_ORG_NAME=

# === Logging ===
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_ENABLED=true
LOG_FILE_LEVEL=DEBUG
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5
LOG_JSON_FORMAT=false
LOG_COLOR=true

# === Provider-specific API Keys ===
# Set the API key for your LLM provider. See ai/model_registry.py for provider list.
# Match the env var name from LiteLLM per-provider requirements.
# Common examples:
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# MINIMAX_API_KEY=...
# QWEN_API_KEY=...
